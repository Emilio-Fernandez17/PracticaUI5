<mvc:View controllerName="practicaui5.practicaui5.controller.PracticaUI5"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:tnt="sap.tnt"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:suite="sap.suite.ui.commons">
    <Page id="page" title="{i18n>title}">

        <OverflowToolbar id="headerToolbar" style="Clear">
            <ToolbarSpacer id="spacer" />
                <Button id="botonIdiomas" text="{i18n>Idioma}" icon="sap-icon://world" press="onButtonPress" type="Transparent" />
                <Button id="botonDatos" text="{i18n>cargar}" icon="sap-icon://refresh" press="cargarDatos" type="Emphasized" />
        </OverflowToolbar>


        <HBox id="layoutHorizontal" width="100%" alignItems="Stretch">
            <items>
                <VBox id="contenedorLista" width="100%">
                    <layoutData>
                        <FlexItemData id="flexDataLista" baseSize="30%" />
                    </layoutData>
                    <items>
                        <tnt:NavigationList id="navigationList" width="100%">
                            <tnt:NavigationListItem id="cabecera" text="{i18n>Cabecera}" icon="sap-icon://business-objects-explorer" items="{modeloSelect>/value}">
                            <tnt:NavigationListItem id="navigationItem" text="{modeloSelect>CardCode}" key="{modeloSelect>CardCode}" />
                            </tnt:NavigationListItem>
                        </tnt:NavigationList>
                    </items>
                </VBox>

                <VBox id="contenedorGrafica" width="100%">
                    <layoutData>
                        <FlexItemData id="flexDataGrafica" growFactor="1" baseSize="70%" />
                    </layoutData>
                    <items>
                        <suite:ChartContainer id="chartContainer" showFullScreen="true" title="{i18n>Grafica}">
                            <suite:content>
                                <suite:ChartContainerContent id="chartContentGrafica" icon="sap-icon://line-chart" title="Line Chart">
                                    <suite:content>
                                        <viz:VizFrame id="chartContainerVizFrame" height="720px" width="100%" uiConfig="{applicationSet:'fiori'}"></viz:VizFrame>
                                    </suite:content>
                                </suite:ChartContainerContent>
                            </suite:content>
                        </suite:ChartContainer>
                    </items>
                </VBox>
        </items>
    </HBox>

        <Text id="a" text="&#10;"/>
        <Table id="idTablaPrueba" width="95%"  items="{Items>/value}" class="sapUiMediumMarginTop sapUiResponsiveMargin" >
            <headerToolbar>
                <OverflowToolbar id="otbTable">
                    <Title id="tableTitle" text="{i18n>titleTable}" level="H2" />
                    <ToolbarSpacer id="spacerTable" />
                    <Button id="anadeArticuloTable" text="{i18n>abrirFormulario}" icon="sap-icon://add" type="Emphasized" press="anadir" />
                </OverflowToolbar>
            </headerToolbar>
            <columns>
                <Column id="colCode"><header><Text id="txtColCode" text="{i18n>ItemCode}" /></header></Column>
                <Column id="colName"><header><Text id="txtColName" text="{i18n>ItemName}" /></header></Column>
                <Column id="colSerie" hAlign="Center"><header><Text id="txtColSerie" text="{i18n>ItemSerie}" /></header></Column>
                <Column id="colLote" hAlign="Center"><header><Text id="txtColLote" text="{i18n>ItemLote}" /></header></Column>
                <Column id="colAlmacenado" hAlign="End"><header><Text id="txtColStock" text="{i18n>stock}" /></header></Column>
                <Column id="colAcciones" hAlign="End" width="8rem"><header><Text id="txtColAcciones" text="Acciones" /></header></Column>
            </columns>
            <items>
                <ColumnListItem id="idFila1">
                    <cells>
                        <Text id="txtCellCode" text="{Items>ItemCode}" />
                        <Text id="txtCellName" text="{Items>ItemName}" />
                        <Text id="txtCellSerie" text="{Items>ManageSerialNumbers}" />
                        <Text id="txtCellLote" text="{Items>ManageBatchNumbers}" />
                        <ObjectNumber id="objStock" number="{Items>QuantityOnStock}" unit="uds" /> 
                        <HBox id="hbAcciones" justifyContent="End">
                            <Button id="btnEditarFila" icon="sap-icon://edit" type="Transparent" press="editar" class="sapUiTinyMarginEnd" />
                            <Button id="btnBorrarFila" icon="sap-icon://delete" type="Reject" press="borrar" />
                        </HBox>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>

        <Panel id="panelFormulario" width="95%" visible="{formulario>/formulario}" class="sapUiMediumMarginTop sapUiResponsiveMargin" accessibleRole="Region">
            <headerToolbar>
                <OverflowToolbar id="otbForm">
                    <Title id="titleForm" text="Detalles del Artículo" />
                </OverflowToolbar>
            </headerToolbar>
            <content>
                <f:SimpleForm id="simpleFormArticulo" editable="true" layout="ResponsiveGridLayout" labelSpanL="3" labelSpanM="3" emptySpanL="4" emptySpanM="4" columnsL="1" columnsM="1">
                    <f:content>
                        <Label id="lblCode" text="{i18n>formCode}" />
                        <MultiInput id="vCode" editable="false" />

                        <Label id="lblName" text="{i18n>formName}" />
                        <MultiInput id="vName" />

                        <Label id="lblSerie" text="{i18n>formSerie}" />
                        <Select id="serie" enabled="{formulario>/cantidad}" change="mostrarlote" width="100%">
                            <items>
                                <core:Item id="serieS" key="S" text="{i18n>si}" />
                                <core:Item id="serieN" key="N" text="{i18n>no}" />  
                            </items>
                        </Select>

                        <Label id="lblLote" text="{i18n>formLote}" visible="{formulario>/lote}" />
                        <Select id="lote" enabled="{formulario>/cantidad}" visible="{formulario>/lote}" width="100%">
                            <items>
                                <core:Item id="loteN" key="N" text="{i18n>no}" />
                                <core:Item id="loteS" key="S" text="{i18n>si}" />
                            </items>
                        </Select>

                        <Label id="lblRepeticion" text="{i18n>repeticion}" visible="{formulario>/repeticion}" />
                        <Text id="txtRepeticion" text=":" visible="{formulario>/repeticion}" />

                        <Label id="lblSpacer" text="" />
                        <HBox id="hboxBotonesForm" class="sapUiSmallMarginTop">
                            <Button id="Anade" text="Añadir" type="Accept" press="anadeArticulo" visible="{formulario>/anade}" class="sapUiTinyMarginEnd" />
                            <Button id="Edita" text="{i18n>EditarBoton}" type="Accept" press="EditaArticulo" visible="{formulario>/editar}" class="sapUiTinyMarginEnd" />
                            <Button id="cancelar" text="{i18n>CancelarBoton}" type="Back" press="ocultarFormulario" />
                        </HBox>
                    </f:content>
                </f:SimpleForm>
            </content>
        </Panel>



    </Page>
</mvc:View>