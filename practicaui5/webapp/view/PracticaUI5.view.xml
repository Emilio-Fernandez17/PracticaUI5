<mvc:View controllerName="practicaui5.practicaui5.controller.PracticaUI5"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

        <Button id="botonIdiomas" text="{i18n>Idioma}" press="onButtonPress"/>

        <Button id="botonDatos" text="cargarDatos" press="cargarDatos"/>
 
       <Select id="select" items="{modeloSelect>/value}">
<core:Item id="option" key="{modeloSelect>CardName}" text="{modeloSelect>CardCode}"/>
</Select>

    </Page>
</mvc:View>