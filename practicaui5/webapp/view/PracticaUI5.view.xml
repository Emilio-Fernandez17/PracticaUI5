<mvc:View controllerName="practicaui5.practicaui5.controller.PracticaUI5"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:tnt="sap.tnt"
    xmlns="sap.m"
    xmlns:suite="sap.suite.ui.commons">
    <Page id="page" title="{i18n>title}">

        <Button id="botonIdiomas" text="{i18n>Idioma}" press="onButtonPress"/>

        <Text id="Prueba" text="{i18n>prueba}"></Text>

        <Button id="botonDatos" text="{i18n>cargar}" press="cargarDatos"/>
 
        <!--<Select id="select" items="{modeloSelect>/value}" change="seleccionar">
            <core:Item id="option" key="{modeloSelect>CardName}" text="{modeloSelect>CardCode}"/>
        </Select>-->

        <tnt:NavigationList id="navigationList" width="500px">
            <tnt:NavigationListItem id="cabecera" text="{i18n>Cabecera}" icon="sap-icon://business-objects-explorer" items="{modeloSelect>/value}">
                <tnt:NavigationListItem id="navigationItem" text="{modeloSelect>CardCode}" key="{modeloSelect>CardCode}" />
            </tnt:NavigationListItem>
        </tnt:NavigationList>


        <Text id="a" text="&#10;"/>
                    <Table id="idTablaPrueba" headerText="Datos de Prueba Directos" items="{modeloSelect>/letras}">
                        <columns>
                            <Column id="colCode"><header><Text id="Code" text="ItemCode" /></header></Column>
                            <Column id="colName"><header><Text id="Name" text="ItemName" /></header></Column>
							<Column id="colSerie"><header><Text id="Serie" text="ManageSerialNumbers" /></header></Column>
							<Column id="colLote"><header><Text id="Lote" text="ManageBatchNumbers" /></header></Column>
							<Column id="colAlmacenado"><header><Text id="Almacenado" text="QuantityOnStock" /></header></Column>
							<Column id="colEditar"><header><Text id="Editar" text="Editar" /></header></Column>
							<Column id="colBorrar"><header><Text id="Borrar" text="Borrar" /></header></Column>
                        </columns>
                        <items>
                            <ColumnListItem id="idFila1">
                                <cells>
                                    <Text id="codeTexto" text="{modeloSelect>clave}" />
                                    <Text id="nameTexto" text="{modeloSelect>clave}" />
									<Text id="serieTexto" text="{modeloSelect>clave}" />
                                    <Text id="loteTexto" text="{modeloSelect>clave}" />
									<Text id="almacenadoTexto" text="{modeloSelect>clave}" />
                                    <Button id="editar" text="Editar" press="editar">
									</Button> <Button id="borrar" text="Borrar" press="borrar"></Button>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

<Button id="anadeArticulo" text="Añadir Articulo" press="mostrarFormulario"></Button>

<VBox id="box" class="contenedor-especial" visible="{formulario>/formulario}">
    <Text id="nCode" text="Codigo:"></Text>
    <MultiInput id="vCode" type="Text"></MultiInput>

    <Text id="nName" text="Nombre:"></Text>
    <MultiInput id="vName" type="Text"></MultiInput>

    <Text id="nSerie" text="Serie:"></Text>
    <Select id="serie" change="mostrarlote">
        <items>
			<core:Item id="serieS" key="S" text="Sí" />
			<core:Item id="serieN" key="N" text="No" />  
        </items>
    </Select>
    
    <Text id="nLote" text="Lote:" visible="{formulario>/lote}"></Text>
    <Select id="lote" visible="{formulario>/lote}">
        <items>
            <core:Item id="loteN" key="N" text="No" />
			<core:Item id="loteS" key="S" text="Sí" />
        </items>
    </Select>

    <HBox id="hbox"  class="sapUiSmallMarginTop" >
        <Button id="Anade" text="Añadir Articulo" type="Emphasized" press="anadeArticulo"></Button>
        <Button id="cancelar" text="Cancelar" press="ocultarFormulario"></Button>
    </HBox>
</VBox>


        <Text id="mensajeCarga" text="Cargue datos para ver la gráfica" visible="true"/>

        <layout:Splitter id="grafica" width="100%" height="100%"  visible="false">
            <layout:contentAreas>
                <suite:ChartContainer id="chartContainer" showFullScreen="true" showPersonalization="false" autoAdjustHeight="false" title="Grafica">
                    <suite:content>
                        <suite:ChartContainerContent id="ChartContainer" icon="sap-icon://line-chart" title="Line Chart">
                            <suite:content>
                                <viz:VizFrame id="chartContainerVizFrame" height="700px" width="100%" uiConfig="{applicationSet:'fiori'}"></viz:VizFrame>
                            </suite:content>
                        </suite:ChartContainerContent>
                    </suite:content>
                </suite:ChartContainer>
            </layout:contentAreas>
	    </layout:Splitter>

    </Page>
</mvc:View>