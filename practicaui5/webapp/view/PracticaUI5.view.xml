<mvc:View controllerName="practicaui5.practicaui5.controller.PracticaUI5"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:tnt="sap.tnt"
    xmlns="sap.m"
    xmlns:suite="sap.suite.ui.commons">
    <Page id="page" title="{i18n>title}">

        <Button id="botonIdiomas" text="{i18n>Idioma}" press="onButtonPress"/>

        <Text id="Prueba" text="{i18n>prueba}"></Text>

        <Button id="botonDatos" text="{i18n>cargar}" press="cargarDatos"/>
 
        <!--<Select id="select" items="{modeloSelect>/value}" change="seleccionar">
            <core:Item id="option" key="{modeloSelect>CardName}" text="{modeloSelect>CardCode}"/>
        </Select>-->

        <tnt:NavigationList id="navigationList" width="500px">
            <tnt:NavigationListItem id="cabecera" text="{i18n>Cabecera}" icon="sap-icon://business-objects-explorer" items="{modeloSelect>/value}">
                <tnt:NavigationListItem id="navigationItem" text="{modeloSelect>CardCode}" key="{modeloSelect>CardCode}" />
            </tnt:NavigationListItem>
        </tnt:NavigationList>


        <Text id="mensajeCarga" text="Cargue datos para ver la gráfica" visible="true"/>

        <layout:Splitter id="grafica" width="100%" height="100%"  visible="false">
            <layout:contentAreas>
                <suite:ChartContainer id="chartContainer" showFullScreen="true" showPersonalization="false" autoAdjustHeight="false" title="Grafica">
                    <suite:content>
                        <suite:ChartContainerContent id="ChartContainer" icon="sap-icon://line-chart" title="Line Chart">
                            <suite:content>
                                <viz:VizFrame id="chartContainerVizFrame" height="700px" width="100%" uiConfig="{applicationSet:'fiori'}"></viz:VizFrame>
                            </suite:content>
                        </suite:ChartContainerContent>
                    </suite:content>
                </suite:ChartContainer>
            </layout:contentAreas>
	    </layout:Splitter>

    </Page>
</mvc:View>